#!/usr/bin/env python3
"""connector-publish — fast stdlib-only CLI used by hooks.

Writes directly to the connector's SQLite. Designed to stay well under
50ms per call: no third-party imports, single connection, no fsync.

Usage:
  connector-publish set-room ROOM
  connector-publish plan       --path PATH      [--room ROOM]
  connector-publish memory     --name NAME --content-file PATH [--room ROOM]
  connector-publish artifact   --path PATH      [--room ROOM]
  connector-publish transcript --content-file PATH [--room ROOM]
  connector-publish note       --text TEXT      [--room ROOM]
  connector-publish join       --room ROOM
  connector-publish leave

All paths are absolute. Fails open: on any error, prints the error to
~/.claude/multi-agent-connector/debug.log and exits 0 so the host
session never sees a hook failure.
"""

from __future__ import annotations

import argparse
import os
import sys
import traceback
from pathlib import Path

# allow `from connector import ...` style import when invoked from anywhere
PLUGIN_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PLUGIN_ROOT))

from connector import db, blobs  # noqa: E402


DEFAULT_ROOM_FILE = db.ROOT / "current_room"


def log_error(exc: BaseException) -> None:
    try:
        db.ensure_root()
        with (db.ROOT / "debug.log").open("a") as f:
            f.write(f"[{db.now()}] {type(exc).__name__}: {exc}\n")
            f.write(traceback.format_exc())
            f.write("\n")
    except Exception:
        pass


def resolve_room(arg_room: str | None) -> str:
    if arg_room:
        return arg_room
    if DEFAULT_ROOM_FILE.exists():
        return DEFAULT_ROOM_FILE.read_text().strip() or "default"
    return "default"


def read_file_capped(path: str, cap: int = 256 * 1024) -> str:
    p = Path(path).expanduser().resolve()
    raw = p.read_bytes()[:cap]
    return raw.decode("utf-8", errors="replace")


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="connector-publish")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_set = sub.add_parser("set-room")
    p_set.add_argument("room")

    for name in ("plan", "artifact"):
        sp = sub.add_parser(name)
        sp.add_argument("--path", required=True)
        sp.add_argument("--room")

    p_mem = sub.add_parser("memory")
    p_mem.add_argument("--name", required=True)
    p_mem.add_argument("--content-file", required=True)
    p_mem.add_argument("--room")

    p_tr = sub.add_parser("transcript")
    p_tr.add_argument("--content-file", required=True)
    p_tr.add_argument("--room")

    p_note = sub.add_parser("note")
    p_note.add_argument("--text", required=True)
    p_note.add_argument("--room")

    p_join = sub.add_parser("join")
    p_join.add_argument("--room", required=True)

    sub.add_parser("leave")

    args = parser.parse_args(argv)

    try:
        if args.cmd == "set-room":
            db.ensure_root()
            DEFAULT_ROOM_FILE.write_text(args.room.strip())
            print(args.room.strip())
            return 0

        room = resolve_room(getattr(args, "room", None))
        if db.room_silent(room) and args.cmd != "leave":
            return 0  # silent mode: don't publish, don't error

        with db.connect() as conn:
            db.get_or_create_room(conn, room)
            session_id = db.upsert_session(conn, room)

            if args.cmd == "join":
                db.insert_event(conn, room, session_id, "session_join", {"cwd": os.getcwd()})
                DEFAULT_ROOM_FILE.write_text(room)
            elif args.cmd == "leave":
                db.insert_event(conn, room, session_id, "session_leave", {})
                db.leave_session(conn, session_id)
            elif args.cmd == "plan":
                payload = {
                    "path": str(Path(args.path).expanduser().resolve()),
                    "content": read_file_capped(args.path),
                }
                db.insert_event(conn, room, session_id, "plan", payload)
            elif args.cmd == "memory":
                payload = {
                    "name": args.name,
                    "content": read_file_capped(args.content_file),
                }
                db.insert_event(conn, room, session_id, "memory_note", payload)
            elif args.cmd == "transcript":
                payload = {"content": read_file_capped(args.content_file)}
                db.insert_event(conn, room, session_id, "transcript_chunk", payload)
            elif args.cmd == "note":
                db.insert_event(conn, room, session_id, "note", {"text": args.text})
            elif args.cmd == "artifact":
                sha, size = blobs.store_blob(room, args.path)
                payload = {
                    "path": str(Path(args.path).expanduser().resolve()),
                    "size": size,
                    "name": Path(args.path).name,
                }
                db.insert_event(conn, room, session_id, "artifact", payload, blob_sha=sha)
        return 0
    except Exception as exc:
        log_error(exc)
        return 0  # fail open


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
